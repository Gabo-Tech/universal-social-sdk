{
  "name": "universal-social-sdk",
  "version": "1.0.1",
  "description": "TypeScript-first universal social media SDK for Node.js",
  "type": "module",
  "license": "MIT",
  "author": "universal-social-sdk contributors",
  "repository": {
    "type": "git",
    "url": "https://github.com/Gabo-Tech/universal-social-sdk.git"
  },
  "homepage": "https://github.com/Gabo-Tech/universal-social-sdk#readme",
  "bugs": {
    "url": "https://github.com/Gabo-Tech/universal-social-sdk/issues"
  },
  "funding": {
    "type": "github",
    "url": "https://github.com/sponsors/Gabo-Tech"
  },
  "keywords": [
    "sdk",
    "social-media",
    "instagram",
    "twitter",
    "x",
    "facebook",
    "linkedin",
    "typescript",
    "ollama"
  ],
  "engines": {
    "node": ">=18.18.0"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md",
    ".env.example",
    ".env.test.example",
    "examples",
    "supported-methods.json"
  ],
  "bin": {
    "universal-social-sdk": "./dist/cli/index.js"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "clean": "rimraf dist",
    "test": "vitest run",
    "test:unit": "vitest run tests/unit",
    "test:integration": "vitest run tests/integration",
    "example:x": "node examples/x-post.mjs",
    "example:instagram": "node examples/instagram-reel.mjs",
    "example:bluesky": "node examples/bluesky-post.mjs",
    "test:watch": "vitest",
    "prepare": "npm run build"
  },
  "dependencies": {
    "axios": "^1.9.0",
    "chalk": "^5.4.1",
    "cheerio": "^1.0.0",
    "commander": "^13.1.0",
    "diff": "^8.0.3",
    "dotenv": "^16.4.7",
    "facebook-nodejs-business-sdk": "^24.0.1",
    "inquirer": "^13.3.0",
    "ora": "^8.2.0",
    "twitter-api-v2": "^1.29.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "rimraf": "^6.0.1",
    "tsup": "^8.4.0",
    "typescript": "^5.8.2",
    "vitest": "^3.0.9"
  }
}
